{
  "seed": 2,
  "device": "auto",
  "out_dir": "runs/oneshot_90pct_rq1",
  "data": {
    "task": "cifar100_binary_pairs",
    "root": "./data",
    "batch_size": 128,
    "num_workers": 0,
    "label_rule": "parity",
    "pairing": "static",
    "data_seed": 12345,
    "noise_std": 0.0
  },
  "teacher_ckpt": "runs/cifar_teacher_final/teacher.pt",
  "teacher_model": {
    "in_channels": 3,
    "width": 16,
    "hidden": 64,
    "shared_encoder": true
  },
  "student_model": {
    "in_channels": 3,
    "width": 16,
    "hidden": 64,
    "shared_encoder": true
  },
  "lr": 0.001,
  "epochs": 40,
  "temperature": 2.0,
  "target_sparsity": 0.9,
  "compute_cka": true,
  "posthoc_prune": {
    "enabled": true,
    "target_sparsity": 0.9,
    "fixed_target_sparsity": true,
    "rerandomize": false
  }
}